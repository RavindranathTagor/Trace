# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies — match node_modules at ANY depth (root, adapters/, demo/video/, …)
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files / secrets — NEVER commit (belt & suspenders)
.env
.env.*
**/.env
**/.env.*
!.env.example
adapters/.env

# runtime state that may contain credentials — MUST NOT be committed
/data/integrations.json
/data/forgotten.json

# adapter deps
/adapters/node_modules

# docs — this repo ships only the README (product docs kept local)
/docs/

# local self-hosted Cognee — this repo is the Cognee CLOUD integration only
/cognee-selfhost/

# scratch / notes
message.txt
_test_ollama.txt
.tmp/

# agent rules files GENERATED from the company brain (npm run brain:rules) —
# regenerate locally; don't commit (may encode internal constraints)
/.cursorrules
/.github/copilot-instructions.md
/CLAUDE.md
/AGENTS.md
/CONVENTIONS.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
