# ---- Hindsight app env TEMPLATE ----
# Copy to .env.local and fill in real values. .env.local is gitignored and is the
# file Next.js actually loads. NEVER put real secrets in this committed template.

# Cognee (self-hosted). Set COGNEE_ENABLED=true once the Docker server is up.
# While false, the app serves the built-in mock decision graph.
COGNEE_ENABLED=false
COGNEE_BASE_URL=http://localhost:8000
COGNEE_DATASET=hindsight
# Single-user cognee (ENABLE_BACKEND_ACCESS_CONTROL=false) => no auth needed.
# Set COGNEE_AUTH=true only if your server has access control on (then set EMAIL/PASSWORD).
COGNEE_AUTH=false
# COGNEE_EMAIL=admin@hindsight.dev
# COGNEE_PASSWORD=change-me-please

# Groq (free) — used for the honest "Stateless AI" baseline (no memory) panel.
# Free key (no card) at https://console.groq.com . Same key powers Cognee's LLM.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ElevenLabs Conversational AI — the PUBLIC agent id (safe to expose to the client).
# Create an agent in the ElevenLabs dashboard with WebRTC + Flash v2.5 + two client tools
# named exactly: searchTeamMemory(query) and highlightSubgraph(nodeIds). See README.
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=

# Cognee Cloud (managed) — set these to use Cloud as PRIMARY (auto-fails over to local).
COGNEE_API_KEY=
COGNEE_TENANT_ID=
# Optional local self-host used as automatic failover when Cloud is slow/down.
COGNEE_FALLBACK_BASE_URL=

# GitHub — PR commenting + webhook auth. When GITHUB_WEBHOOK_SECRET is set the
# webhook verifies signatures (fail-closed); unset = fail-open (dev only).
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Slack Events API request signing secret. When set, /api/slack/events verifies
# X-Slack-Signature (+5-min replay window); unset = accept unverified (dev only).
SLACK_SIGNING_SECRET=
